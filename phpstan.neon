includes:
    # Extension WordPress pour reconnaître les fonctions globales (__, _e, esc_html, etc.)
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
    # Faux positifs connus : propriétés WordPress existantes absentes des stubs
    - phpstan-baseline.neon

parameters:
    # Niveau de vérification (0 = basique, 9 = très strict)
    level: 8

    # Chemins à analyser (adapte selon la structure de ton plugin)
    paths:
        - src
        - tests

    # Exclure certains fichiers/dossiers (ex: vendor, node_modules)
    excludePaths:
        analyse:
            - vendor/*
            - node_modules/*
            - *.min.js
            - *.min.css
            - tests/bootstrap.php

    # Ignorer les erreurs pour des fichiers spécifiques
    ignoreErrors: []

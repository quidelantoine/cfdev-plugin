{
  "name": "weblitzer/cfdev-plugin",
  "type": "wordpress-plugin",
  "autoload": {
    "psr-4": {
      "Weblitzer\\CFDev\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Weblitzer\\CFDev\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "brain/monkey": "^2.7",
    "automattic/vipwpcs": "^3.0",
    "phpstan/phpstan": "^2.1",
    "szepeviktor/phpstan-wordpress": "^2.0"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
